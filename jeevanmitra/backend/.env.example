# Copy this file to .env and fill in your values.

# Get a free key from https://console.groq.com (API Keys -> Create API Key)
GROQ_API_KEY=gsk_your_key_here

# Port the backend server listens on
PORT=3000

# Optional: override the default Groq model IDs
# (check https://console.groq.com/docs/models for current options)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Set to "true" to have this backend also serve the ../frontend folder
# as static files (handy for local dev / single-service deployment)
SERVE_FRONTEND=false
